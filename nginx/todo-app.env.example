# Copy this file to /etc/todo-app.env on the server and fill in real values.
# Keep /etc/todo-app.env private:
#   sudo chown root:root /etc/todo-app.env
#   sudo chmod 600 /etc/todo-app.env

SECRET_KEY_BASE=replace-with-bin-rails-secret-output
RAILS_MASTER_KEY=replace-with-config-master-key
DATABASE_URL=mysql2://todo_user:strong_password@localhost/rails_production
RAILS_LOG_LEVEL=info
