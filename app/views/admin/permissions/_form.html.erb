<%= form_with(model: [:admin, permission], class: "contents") do |form| %>
  <% if permission.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(permission.errors.count, "error") %> prohibited this permission from being saved:</h2>

      <ul>
        <% permission.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :name, "Permission Name" %>
    <%= form.text_field :name, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full", placeholder: "e.g. Manage Tasks" %>
  </div>

  <div class="my-5">
    <%= form.label :resource, "Module / Resource" %>
    <%= form.select :resource, ['Tasks', 'Projects', 'Users', 'Roles', 'Comments', 'System'], { prompt: "Select a module" }, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full bg-white" %>
  </div>

  <div class="my-5 flex space-x-4">
    <div class="w-1/2">
      <%= form.label :action, "Action" %>
      <%= form.select :action, ['create', 'read', 'update', 'delete', 'manage'], { prompt: "Select action" }, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full bg-white" %>
    </div>
  </div>

  <div class="my-5">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 4, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="inline">
    <%= form.submit class: "rounded-lg py-3 px-5 bg-blue-600 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>