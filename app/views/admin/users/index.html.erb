<div class="max-w-4xl mx-auto mt-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Manage Users</h1>
    <%= link_to "New User", new_admin_user_path, class: "bg-[#0073ea] hover:bg-[#0060b9] text-white font-medium py-2 px-4 rounded transition" %>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden border border-[#d0d4e4]">
    <table class="min-w-full divide-y divide-[#d0d4e4]">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-[#d0d4e4]">
        <% @users.each do |user| %>
          <tr class="hover:bg-gray-50 transition duration-150">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.id %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= user.email %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= user.owner? ? 'bg-purple-100 text-purple-800' : (user.admin? ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800') %>">
                <%= user.role.capitalize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
              <%= link_to "Edit", edit_admin_user_path(user), class: "text-[#0073ea] hover:text-[#0060b9] transition" %>
              <% if user != current_user %>
                <%= link_to "Delete", admin_user_path(user), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-500 hover:text-red-700 transition" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>