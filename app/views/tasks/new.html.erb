<% content_for :title, "New Task" %>

<div class="flex justify-center items-center min-h-screen bg-gray-100 w-full">
  <div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-md">
    <h1 class="text-2xl font-bold text-center text-gray-800 mb-6">
      New Task
    </h1>

    <%= render "form", task: @task %>

    <div class="mt-6 text-center">
      <%= link_to "← Back to Tasks", tasks_path,
          class: "text-amber-600 hover:text-amber-700 font-medium transition duration-150" %>
    </div>
  </div>
</div>
