<div id="<%= dom_id task %>" class="bg-white rounded-xl shadow-md p-6 border border-gray-100 hover:shadow-lg transition duration-300">
  <div class="mb-3">
    <h2 class="text-xl font-semibold text-gray-800"><%= task.title %></h2>
  </div>

  <div class="mb-4">
    <p class="text-gray-600"><%= task.description.presence || "No description provided." %></p>
  </div>

  <div class="flex flex-wrap gap-3 text-sm">
    <span class="px-3 py-1 bg-blue-100 text-blue-700 font-medium rounded-full">
      Status: <%= task.status.capitalize %>
    </span>
    <span class="px-3 py-1 bg-amber-100 text-amber-700 font-medium rounded-full">
      Priority: <%= task.priority.capitalize %>
    </span>
  </div>
</div>
