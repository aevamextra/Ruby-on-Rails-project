<p class="text-green-600 text-center font-medium mb-4"><%= notice %></p>

<div class="min-h-screen bg-gray-100 flex justify-center items-center py-10">
  <div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-md border border-gray-100">
    <h1 class="text-2xl font-bold text-center text-gray-800 mb-6">Task Details</h1>

    <div class="space-y-4 text-gray-700">
      <div>
        <span class="font-semibold text-gray-800">Title:</span>
        <p class="mt-1"><%= @task.title %></p>
      </div>

      <div>
        <span class="font-semibold text-gray-800">Description:</span>
        <p class="mt-1"><%= @task.description.presence || "No description provided." %></p>
      </div>

      <div>
        <span class="font-semibold text-gray-800">Status:</span>
        <span class="ml-2 px-3 py-1 rounded-full text-sm font-semibold 
          <%= @task.status == 'completed' ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700' %>">
          <%= @task.status.capitalize %>
        </span>
      </div>

      <div>
        <span class="font-semibold text-gray-800">Priority:</span>
        <span class="ml-2 px-3 py-1 rounded-full text-sm font-semibold 
          <%= @task.priority == 'high' ? 'bg-red-100 text-red-700' : @task.priority == 'medium' ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-700' %>">
          <%= @task.priority.capitalize %>
        </span>
      </div>
    </div>

    <div class="mt-8 flex justify-between items-center">
      <%= link_to "← Back to Tasks", tasks_path,
          class: "text-amber-600 hover:text-amber-700 font-medium transition duration-150" %>

      <div class="flex space-x-3">
        <%= link_to "Edit", edit_task_path(@task),
            class: "px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-md shadow-sm transition duration-200" %>

        <%= button_to "Delete", @task,
            method: :delete,
            data: { turbo_confirm: "Are you sure?" },
            class: "px-4 py-2 bg-red-500 hover:bg-red-600 text-white font-semibold rounded-md shadow-sm transition duration-200" %>
      </div>
    </div>
  </div>
</div>
