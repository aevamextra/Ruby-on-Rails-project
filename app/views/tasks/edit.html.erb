<% content_for :title, "Edit Task" %>

<div class="flex justify-center items-center min-h-screen bg-gray-100 w-full">
  <div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-md">
   

    <%= render "form", task: @task %>

    <div class="mt-6 flex justify-between text-sm font-medium">
      <%= link_to "← Back to Tasks", tasks_path,
          class: "text-amber-600 hover:text-amber-700 transition duration-150" %>

      <%= link_to "View Task", @task,
          class: "text-blue-600 hover:text-blue-700 transition duration-150" %>
    </div>
  </div>
</div>
