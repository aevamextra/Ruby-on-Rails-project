<% content_for :title, params[:scope] == 'all' ? "All Tasks" : "My Tasks" %>

<div class="min-h-screen bg-gray-100 flex flex-col items-center py-10 px-4">
  <h1 class="text-3xl font-bold text-gray-800 mb-8"><%= params[:scope] == 'all' ? "All Tasks" : "My Tasks" %></h1>
<div class="flex justify-center my-6">
 <%= form_with url: tasks_path, method: :get, local: true, class: "flex space-x-4 items-center mb-6" do |form| %>
  <%= form.hidden_field :scope, value: params[:scope] %>
  
  <!-- Search box -->
  <%= form.text_field :search, value: params[:search], placeholder: "Search tasks...", 
        class: "border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-violet-500" %>

  <!-- Status dropdown -->
  <%= form.select :status, 
        options_for_select([["All Statuses", ""],["In Progress", "inprogress"], ["Done", "done"],["Archived", "archived"]], params[:status]),
        {}, 
        class: "border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-violet-500" %>

  <!-- Priority dropdown -->
  <%= form.select :priority, 
        options_for_select([["All Priorities", ""], ["Low", "low"], ["Medium", "medium"], ["High", "high"]], params[:priority]),
        {}, 
        class: "border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-violet-500" %>
  <%= form.select :sort, 
        options_for_select([["Asc", "priority_asc"], ["Desc", "priority_desc"]], params[:sort]),
        {}, 
        class: "border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-violet-500" %>

  <!-- Submit button -->
  <%= form.submit "Filter", 
        class: "bg-violet-500 hover:bg-violet-600 text-white font-semibold px-6 py-2 rounded-lg shadow-sm transition duration-200" %>
<% end %>

 
</div>
  <!-- Table Wrapper -->
  <div class="w-full max-w-6xl bg-white shadow-md rounded-xl overflow-hidden border border-gray-200">
    <table class="min-w-full text-left text-sm text-gray-700">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="py-3 px-6 font-semibold text-gray-900">Title</th>
          <th class="py-3 px-6 font-semibold text-gray-900">Description</th>
          <th class="py-3 px-6 font-semibold text-gray-900 text-center">Status</th>
          <th class="py-3 px-6 font-semibold text-gray-900 text-center">Priority</th>
          <th class="py-3 px-6 font-semibold text-gray-900 text-center">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @tasks.each do |task| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="py-4 px-6 font-medium text-gray-800"><%= task.title %></td>
            <td class="py-4 px-6 text-gray-600"><%= task.description.presence || "No description provided." %></td>
            <td class="py-4 px-6 text-center">
              <span class="px-3 py-1 rounded-full text-sm font-semibold 
                <%= task.status == 'done' && 'bg-green-100 text-green-700' %>
                <%= task.status == 'inprogress' && 'bg-blue-100 text-blue-700' %>
                <%= task.status == 'archived' && 'bg-red-100 text-red-700' %>
                
                ">
                <%= task.status.capitalize %>
              </span>
            </td>
            <td class="py-4 px-6 text-center">
              <span class="px-3 py-1 rounded-full text-sm font-semibold 
                <%= task.priority == 'urgent' ? 'bg-red-100 text-red-700' : task.priority == 'high' ? 'bg-amber-100 text-amber-700' : 'bg-green-100 text-green-700' %>">
                <%= task.priority.capitalize %>
              </span>
            </td>
            <td class="py-4 px-6 text-center space-x-3">
              <%= link_to "Show", task, class: "text-blue-600 hover:text-blue-700 font-medium" %>
              <%= link_to "Edit", edit_task_path(task), class: "text-amber-600 hover:text-amber-700 font-medium" %>
              <%= link_to "Delete", task, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-700 font-medium" %>
            </td>
          </tr>
        <% end %>
      </tbody>
      
    </table>
  <div class="flex justify-center items-center my-6 float-end mr-5">
  <span class="bg-gray-200 text-gray-800 px-5 py-2 rounded-2xl font-semibold text-sm shadow-md">
    Page <%= @currentPage %> of <%= @numberOfPage %>
  </span>
</div>

  </div>

  <!-- New Task Button -->
  <div class="mt-8 flex justify-center items-center gap-5">
    <% if @currentPage > 1 %>
      <%= link_to "Previous", tasks_path(page: @currentPage - 1, scope: params[:scope], search: params[:search], priority: params[:priority], status: params[:status], sort: params[:sort]), class: "inline-block bg-blue-500 hover:bg-blue-600 text-white font-semibold px-6 py-3 rounded-lg shadow-sm transition duration-200" %>
    <% end %>
    
    <% unless params[:scope] == 'all' %>
      <%= link_to " New Task", new_task_path,
          class: "inline-block bg-amber-500 hover:bg-amber-600 text-white font-semibold px-6 py-3 rounded-lg shadow-sm transition duration-200" %>
    <% end %>

    <% if @currentPage < @numberOfPage %>
       <%= link_to "Next", tasks_path(page: @currentPage + 1, scope: params[:scope], search: params[:search], priority: params[:priority], status: params[:status], sort: params[:sort]), class: "inline-block bg-violet-500 hover:bg-violet-600 text-white font-semibold px-6 py-3 rounded-lg shadow-sm transition duration-200"%>
    <% end %>
  </div>

</div>
