<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Todo App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- TailwindCSS -->
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <!-- Importmap JS -->
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 text-gray-800 min-h-screen flex flex-col">
    <nav class="bg-violet-600 text-white p-4">
      <div class="container mx-auto flex justify-between items-center">
        <%= link_to "Todo App", root_path, class: "text-xl font-bold" %>
        <div class="space-x-4">
          <% if logged_in? %>
            <span class="text-violet-200">Logged in as <%= current_user.email %></span>
            <%= link_to "Logout", logout_path, data: { turbo_method: :delete }, class: "hover:text-violet-300" %>
          <% else %>
            <%= link_to "Log In", login_path, class: "hover:text-violet-300" %>
            <%= link_to "Sign Up", signup_path, class: "bg-white text-violet-600 px-3 py-1 rounded hover:bg-gray-100" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="container mx-auto mt-6 px-5 grow">
      <% if flash[:notice] %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
