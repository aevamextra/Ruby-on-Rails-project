<% content_for :title, @project.name %>

<div class="min-h-screen bg-white text-gray-900 pb-10">
  
  <!-- Header Area -->
  <div class="px-8 pt-8 pb-4 border-b border-gray-200">
    <div class="flex flex-col mb-4">
      <div class="flex items-center justify-between">
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 mb-1">
          <%= @project.name %>
        </h1>
        <div class="flex space-x-2">
          <%= link_to "Edit Project", edit_project_path(@project), class: "text-sm text-gray-500 hover:text-[#0073ea]" %>
          <%= button_to "Delete", @project, method: :delete, class: "text-sm text-red-400 hover:text-red-500 cursor-pointer" %>
        </div>
      </div>
      <p class="text-sm text-gray-500"><%= @project.description.presence || "Track and manage your workflow efficiently." %></p>
    </div>

    <!-- Filter Bar (Sleek) -->
    <%= form_with url: project_path(@project), method: :get, local: true, class: "flex flex-wrap gap-3 items-center text-sm" do |form| %>
      
      <!-- Search box -->
      <div class="relative">
        <%= form.text_field :search, value: params[:search], placeholder: "Search tasks...", 
            class: "px-3 py-1.5 border border-gray-300 rounded-full focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 w-48 text-sm" %>
      </div>

      <!-- Status dropdown -->
      <%= form.select :status, 
            options_for_select([["Status", ""],["In Progress", "inprogress"], ["Done", "done"],["Archived", "archived"]], params[:status]),
            {}, 
            class: "px-3 py-1.5 border border-gray-300 rounded-full focus:outline-none focus:border-blue-500 text-sm" %>

      <!-- Priority dropdown -->
      <%= form.select :priority, 
            options_for_select([["Priority", ""], ["Low", "low"], ["Medium", "medium"], ["High", "high"]], params[:priority]),
            {}, 
            class: "px-3 py-1.5 border border-gray-300 rounded-full focus:outline-none focus:border-blue-500 text-sm" %>

      <%= form.select :sort, 
            options_for_select([["Sort By", ""], ["Priority (Asc)", "priority_asc"], ["Priority (Desc)", "priority_desc"]], params[:sort]),
            {}, 
            class: "px-3 py-1.5 border border-gray-300 rounded-full focus:outline-none focus:border-blue-500 text-sm" %>

      <!-- Submit button -->
      <%= form.submit "Filter", 
            class: "bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium px-4 py-1.5 rounded-full border border-gray-300 cursor-pointer transition duration-150" %>
    <% end %>
  </div>

  <!-- Main Board Area -->
  <div class="px-8 mt-6">
    <div class="w-full bg-white shadow-sm border border-gray-200 rounded-md overflow-hidden">
      
      <!-- Monday-style Table -->
      <table class="w-full text-left text-sm whitespace-nowrap table-fixed">
        <thead class="bg-white border-b-2 border-gray-200 text-gray-500">
          <tr>
            <th class="py-3 px-4 font-normal w-1/3">Item</th>
            <th class="py-3 px-4 font-normal w-1/4">Description</th>
            <th class="py-3 px-4 font-normal text-center w-36">Status</th>
            <th class="py-3 px-4 font-normal text-center w-36">Priority</th>
            <th class="py-3 px-4 font-normal text-center w-32">Actions</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-200">
          <% @tasks.each do |task| %>
            <tr class="hover:bg-gray-50 group border-l-4 border-blue-500 transition-colors">
              <td class="py-2.5 px-4 font-medium text-gray-900 truncate"><%= task.title %></td>
              <td class="py-2.5 px-4 text-gray-500 truncate"><%= task.description.presence || "—" %></td>
              
              <!-- Status Cell (Monday.com Style full block) -->
              <td class="p-px border-x border-gray-200 text-center relative w-36 h-10">
                <div class="w-full h-full flex items-center justify-center text-white text-[13px] font-medium transition-colors cursor-pointer
                  <%= task.status == 'done' ? 'bg-[#00c875]' : '' %>
                  <%= task.status == 'inprogress' ? 'bg-[#fdab3d]' : '' %>
                  <%= task.status == 'archived' ? 'bg-[#c4c4c4]' : '' %>
                  <%= task.status.blank? ? 'bg-gray-200 text-gray-500' : '' %>
                  ">
                  <%= task.status.blank? ? 'Set Status' : (task.status == 'inprogress' ? 'Working on it' : task.status.to_s.capitalize) %>
                </div>
              </td>

              <!-- Priority Cell (Monday.com Style full block) -->
              <td class="p-px border-x border-gray-200 text-center relative w-36 h-10">
                <div class="w-full h-full flex items-center justify-center text-white text-[13px] font-medium transition-colors cursor-pointer
                  <%= task.priority == 'urgent' ? 'bg-[#e2445c]' : '' %>
                  <%= task.priority == 'high' ? 'bg-[#a25ddc]' : '' %>
                  <%= task.priority == 'medium' ? 'bg-[#0086c0]' : '' %>
                  <%= task.priority == 'low' ? 'bg-[#579bfc]' : '' %>
                  <%= task.priority.blank? ? 'bg-gray-200 text-gray-500' : '' %>
                  ">
                  <%= task.priority.blank? ? 'Set Priority' : task.priority.to_s.capitalize %>
                </div>
              </td>

              <!-- Actions -->
              <td class="py-2.5 px-4 text-center">
                <div class="flex items-center justify-center space-x-2 opacity-50 group-hover:opacity-100 transition-opacity">
                  <%= link_to "Open", task, class: "text-blue-500 hover:text-blue-700 bg-blue-50 px-2 py-1 rounded text-xs" %>
                  <% if task.user_id == current_user.id %>
                    <%= link_to "✎", edit_task_path(task), class: "text-gray-500 hover:text-gray-700 font-bold" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>

          <!-- "Add new item" row at the bottom (Monday style) -->
          <% unless params[:scope] == 'all' %>
            <tr class="border-l-4 border-gray-300 hover:bg-gray-50 transition-colors">
              <td colspan="5" class="py-2 px-4">
                <%= link_to "+ Add Item", new_task_path(project_id: @project.id), class: "text-gray-400 hover:text-blue-500 font-medium text-sm block w-full outline-none" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination & Bottom Controls -->
    <div class="mt-4 flex justify-between items-center text-sm text-gray-500">
      <div>
        Showing <%= @tasks.length %> tasks (Page <%= @currentPage %> of <%= [@numberOfPage, 1].max %>)
      </div>
      
      <div class="flex items-center space-x-2">
        <% if @currentPage > 1 %>
          <%= link_to "← Prev", project_path(@project, page: @currentPage - 1, search: params[:search], priority: params[:priority], status: params[:status], sort: params[:sort]), class: "px-3 py-1 hover:bg-gray-100 rounded border border-gray-200" %>
        <% end %>

        <% if @currentPage < @numberOfPage %>
          <%= link_to "Next →", project_path(@project, page: @currentPage + 1, search: params[:search], priority: params[:priority], status: params[:status], sort: params[:sort]), class: "px-3 py-1 hover:bg-gray-100 rounded border border-gray-200" %>
        <% end %>
      </div>
    </div>

  </div>
</div>