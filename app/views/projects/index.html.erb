<% content_for :title, "Projects" %>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Projects</h1>
    <%= link_to "New project", new_project_path, class: "bg-[#0073ea] hover:bg-[#0060b9] text-white font-medium py-2 px-4 rounded transition" %>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden border border-[#d0d4e4]">
    <% if @projects.any? %>
      <table class="min-w-full divide-y divide-[#d0d4e4]">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Owner</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-[#d0d4e4]">
          <% @projects.each do |project| %>
            <tr class="hover:bg-gray-50 transition duration-150">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= link_to project.name, project, class: "hover:text-[#0073ea]" %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500 truncate max-w-xs"><%= project.description %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if project.user %>
                  <%= project.user.email %>
                <% else %>
                  <span class="text-gray-400 italic">Unassigned</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
                <%= link_to "Edit", edit_project_path(project), class: "text-[#0073ea] hover:text-[#0060b9] transition" %>
                <%= link_to "Delete", project, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-500 hover:text-red-700 transition" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-10 text-center">
        <p class="text-gray-500 text-sm mb-4">You haven't created any projects yet.</p>
        <%= link_to "Create your first project", new_project_path, class: "text-[#0073ea] hover:text-[#0060b9] font-medium" %>
      </div>
    <% end %>
  </div>
</div>
