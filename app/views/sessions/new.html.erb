<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-lg shadow-md">
  <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">Log In</h1>

  <%= form_with url: login_path, local: true do |f| %>
    <div class="mb-4">
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, class: "w-full border-gray-300 rounded focus:ring-violet-500 focus:border-violet-500" %>
    </div>

    <div class="mb-6">
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, class: "w-full border-gray-300 rounded focus:ring-violet-500 focus:border-violet-500" %>
    </div>

    <%= f.submit "Log In", class: "w-full bg-violet-600 hover:bg-violet-700 text-white font-bold py-2 px-4 rounded" %>
  <% end %>

  <div class="mt-4 text-center">
    <%= link_to "Don't have an account? Sign up", signup_path, class: "text-violet-600 hover:underline" %>
  </div>
</div>
