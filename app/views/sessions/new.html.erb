<div class="flex justify-center items-center h-full bg-[#f5f6f8]">
  <div class="bg-white rounded-lg shadow-[0_4px_12px_rgba(0,0,0,0.06)] border border-[#d0d4e4] w-full max-w-md my-16 px-10 py-12">
    
    <div class="text-center mb-8">
      <h1 class="text-[32px] font-bold text-[#323338] tracking-tight mb-2">Log in to your account</h1>
      <p class="text-gray-500 text-sm font-medium">Welcome back! Please enter your details.</p>
    </div>

    <%= form_with url: login_path, local: true, class: "space-y-5" do |f| %>
      <div>
        <%= f.label :email, "Work email", class: "block text-[#323338] text-[14px] font-medium mb-1.5" %>
        <%= f.email_field :email, class: "w-full border border-[#c3c6d4] focus:border-[#0073ea] focus:ring-1 focus:ring-[#0073ea] rounded transition px-4 py-2.5 outline-none text-[15px]", placeholder: "name@company.com" %>
      </div>

      <div>
        <div class="flex justify-between items-center mb-1.5">
          <%= f.label :password, class: "block text-[#323338] text-[14px] font-medium" %>
        </div>
        <%= f.password_field :password, class: "w-full border border-[#c3c6d4] focus:border-[#0073ea] focus:ring-1 focus:ring-[#0073ea] rounded transition px-4 py-2.5 outline-none text-[15px]", placeholder: "••••••••" %>
      </div>

      <%= f.submit "Log in", class: "w-full bg-[#0073ea] hover:bg-[#0060b9] text-white font-medium py-3 rounded mt-2 transition cursor-pointer text-[15px]" %>
    <% end %>

    <div class="mt-8 text-center border-t border-[#d0d4e4] pt-6">
      <p class="text-[14px] text-gray-500">
        Don't have an account? 
        <%= link_to "Sign up", signup_path, class: "text-[#0073ea] font-medium hover:underline" %>
      </p>
    </div>
  </div>
</div>