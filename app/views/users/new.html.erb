<div class="flex justify-center items-center h-full bg-[#f5f6f8]">
  <div class="bg-white rounded-lg shadow-[0_4px_12px_rgba(0,0,0,0.06)] border border-[#d0d4e4] w-full max-w-md my-16 px-10 py-12">
    
    <div class="text-center mb-8">
      <h1 class="text-[32px] font-bold text-[#323338] tracking-tight mb-2">Sign up for free</h1>
      <p class="text-gray-500 text-sm font-medium">Join over 225,000 customers who trust us.</p>
    </div>

    <%= form_with model: @user, url: users_path, local: true, class: "space-y-5" do |f| %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 text-[#e2445c] p-3 border border-red-200 rounded text-[13px] mb-4">
          <ul class="list-disc pl-4 space-y-1">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :email, "Work email", class: "block text-[#323338] text-[14px] font-medium mb-1.5" %>
        <%= f.email_field :email, class: "w-full border border-[#c3c6d4] focus:border-[#0073ea] focus:ring-1 focus:ring-[#0073ea] rounded transition px-4 py-2.5 outline-none text-[15px]", placeholder: "name@company.com" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-[#323338] text-[14px] font-medium mb-1.5" %>
        <%= f.password_field :password, class: "w-full border border-[#c3c6d4] focus:border-[#0073ea] focus:ring-1 focus:ring-[#0073ea] rounded transition px-4 py-2.5 outline-none text-[15px]", placeholder: "Minimum 8 characters" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm password", class: "block text-[#323338] text-[14px] font-medium mb-1.5" %>
        <%= f.password_field :password_confirmation, class: "w-full border border-[#c3c6d4] focus:border-[#0073ea] focus:ring-1 focus:ring-[#0073ea] rounded transition px-4 py-2.5 outline-none text-[15px]" %>
      </div>

      <%= f.submit "Continue", class: "w-full bg-[#0073ea] hover:bg-[#0060b9] text-white font-medium py-3 rounded mt-2 transition cursor-pointer text-[15px]" %>
    <% end %>

    <div class="mt-8 text-center border-t border-[#d0d4e4] pt-6">
      <p class="text-[14px] text-gray-500">
        Already have an account? 
        <%= link_to "Log in", login_path, class: "text-[#0073ea] font-medium hover:underline" %>
      </p>
    </div>
  </div>
</div>