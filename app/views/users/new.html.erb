<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-lg shadow-md">
  <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">Sign Up</h1>

  <%= form_with model: @user, url: users_path, local: true do |f| %>
    <% if @user.errors.any? %>
      <div class="bg-red-100 text-red-700 p-4 rounded mb-4">
        <ul>
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, class: "w-full border-gray-300 rounded focus:ring-violet-500 focus:border-violet-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, class: "w-full border-gray-300 rounded focus:ring-violet-500 focus:border-violet-500" %>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, class: "w-full border-gray-300 rounded focus:ring-violet-500 focus:border-violet-500" %>
    </div>

    <%= f.submit "Create Account", class: "w-full bg-violet-600 hover:bg-violet-700 text-white font-bold py-2 px-4 rounded" %>
  <% end %>

  <div class="mt-4 text-center">
    <%= link_to "Already have an account? Log in", login_path, class: "text-violet-600 hover:underline" %>
  </div>
</div>
